<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>📚 Литературный дневник</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #f5f3f0;  /* тёплый книжный фон */
      min-height: 100vh;
      padding: 20px 16px 32px;
      color: #2e2e2e;
      -webkit-font-smoothing: antialiased;
    }

    /* основной контейнер — как холст для записей */
    .app {
      max-width: 480px;
      margin: 0 auto;
    }

    /* заголовок с тёплой эстетикой */
    .app-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    h1 {
      font-size: 30px;
      font-weight: 600;
      letter-spacing: -0.5px;
      background: linear-gradient(135deg, #4a3b2c 0%, #7f5e3a 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin: 0;
    }

    .stats-badge {
      background: rgba(255, 245, 235, 0.8);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      padding: 6px 12px;
      border-radius: 40px;
      font-size: 15px;
      font-weight: 500;
      color: #5c4a36;
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
      border: 1px solid rgba(200, 170, 140, 0.2);
    }

    /* секции — плавные, воздушные */
    section {
      margin-bottom: 24px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    h2 {
      font-size: 20px;
      font-weight: 600;
      color: #3e3326;
      letter-spacing: -0.3px;
    }

    .count-badge {
      background: #e6ddd2;
      color: #4f3f2e;
      padding: 4px 10px;
      border-radius: 24px;
      font-size: 14px;
      font-weight: 500;
    }

    /* карточки книг — визитная карточка приложения */
    .book-grid {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .book-card {
      background: #ffffffd9;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      background: rgba(255, 255, 255, 0.9);
      border-radius: 24px;
      padding: 16px;
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.04), 0 2px 4px rgba(0, 0, 0, 0.02);
      border: 1px solid #f0e7de;
      transition: transform 0.2s ease;
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .book-cover {
      width: 60px;
      height: 80px;
      background: #d9cdc0;
      border-radius: 10px;
      box-shadow: 0 6px 10px rgba(0, 0, 0, 0.06);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6b5843;
      font-size: 26px;
      flex-shrink: 0;
      background: linear-gradient(145deg, #f1ebe4, #e3d9cf);
    }

    .book-info {
      flex: 1;
    }

    .book-title {
      font-weight: 650;
      font-size: 17px;
      line-height: 1.3;
      color: #2e241b;
      margin-bottom: 4px;
    }

    .book-author {
      font-size: 14px;
      color: #7b6e5d;
      margin-bottom: 8px;
    }

    .progress-area {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .progress-bar-bg {
      flex: 1;
      height: 6px;
      background: #e5dbd0;
      border-radius: 20px;
      overflow: hidden;
    }

    .progress-bar-fill {
      height: 6px;
      background: #b28b6d;
      border-radius: 20px;
      width: 0%;
    }

    .progress-text {
      font-size: 13px;
      font-weight: 500;
      color: #6b5843;
      min-width: 45px;
    }

    /* заметки / рецензии */
    .notes-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .note-card {
      background: #fffbf8;
      border-radius: 20px;
      padding: 16px;
      border-left: 6px solid #b28b6d;
      box-shadow: 0 3px 8px rgba(0,0,0,0.02);
    }

    .note-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 6px;
    }

    .note-book {
      font-weight: 600;
      color: #4f3a27;
    }

    .note-date {
      font-size: 12px;
      color: #a3927e;
    }

    .note-quote {
      font-style: italic;
      color: #4e4032;
      margin: 6px 0 4px;
      padding-left: 6px;
      border-left: 2px solid #cfbba8;
    }

    .note-text {
      font-size: 14px;
      line-height: 1.45;
      color: #3f352b;
    }

    /* кнопка добавления — плавающая, как в лучших iOS-приложениях */
    .fab-add {
      display: flex;
      align-items: center;
      justify-content: center;
      background: #6f5e4e;
      color: white;
      border: none;
      border-radius: 60px;
      padding: 14px 24px;
      font-size: 18px;
      font-weight: 500;
      box-shadow: 0 8px 20px rgba(90, 70, 50, 0.2);
      margin-top: 16px;
      width: fit-content;
      margin-left: auto;
      margin-right: auto;
      transition: 0.15s;
      cursor: pointer;
      border: 1px solid #8f7a64;
      backdrop-filter: blur(4px);
      gap: 6px;
    }

    .fab-add:active {
      opacity: 0.8;
      transform: scale(0.98);
      box-shadow: 0 4px 10px rgba(70, 50, 30, 0.2);
    }

    /* статистика — наглядно и по-читательски */
    .stats-container {
      background: #e8dfd5;
      border-radius: 28px;
      padding: 18px 20px;
      margin-top: 6px;
      box-shadow: inset 0 1px 3px rgba(255,255,255,0.8), 0 4px 8px rgba(0,0,0,0.02);
    }

    .stat-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
    }

    .stat-label {
      color: #4f3e2d;
      font-weight: 500;
    }

    .stat-number {
      font-weight: 700;
      color: #2b1f14;
    }

    .quote-of-day {
      margin-top: 14px;
      font-style: italic;
      padding: 10px 0 0;
      border-top: 1px dashed #bcab9a;
      color: #5d4b37;
    }

    /* навигация — внизу */
    .tab-bar {
      display: flex;
      justify-content: space-around;
      background: rgba(250, 245, 240, 0.8);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      padding: 10px 6px;
      border-radius: 40px;
      margin-top: 24px;
      border: 1px solid #e3d6ca;
    }

    .tab-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      color: #7f6e5c;
      font-size: 12px;
      transition: 0.1s;
      opacity: 0.8;
    }

    .tab-item.active {
      color: #634d37;
      font-weight: 500;
      opacity: 1;
    }

    .tab-icon {
      font-size: 22px;
      margin-bottom: 2px;
    }

    /* тёмная тема (поддержка системной) */
    @media (prefers-color-scheme: dark) {
      body {
        background: #1f1b17;
        color: #ede7df;
      }
      .book-card, .note-card {
        background: rgba(40, 35, 30, 0.9);
        border-color: #3f362c;
      }
      .book-title { color: #f0e6db; }
      .book-author { color: #b9aa99; }
      .progress-bar-bg { background: #3d3228; }
      .progress-bar-fill { background: #c9aa8b; }
      .stats-container { background: #2c2620; }
      .stat-label, .note-date { color: #bbaa99; }
      .tab-bar { background: #2a241ee0; border-color:#4e4136; }
      .fab-add { background: #7d6854; }
      h1 { background: linear-gradient(135deg, #e6d7c4, #ccb59b); -webkit-background-clip: text; background-clip: text; }
    }

    /* кнопка удаления/действий для демонстрации — мягкая */
    .action-icon {
      background: none;
      border: none;
      font-size: 22px;
      cursor: pointer;
      padding: 6px;
      color: #7f6e5c;
    }

    /* утилиты */
    .flex-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .mt-2 { margin-top: 8px; }
    .text-small { font-size: 13px; }
  </style>
</head>
<body>
<div class="app">
  <!-- заголовок -->
  <div class="app-header">
    <h1>📖 Литературный<br>дневник</h1>
    <div class="stats-badge">📊 7 дней подряд</div>
  </div>

  <!-- Текущее чтение (главный трекер) -->
  <section>
    <div class="section-header">
      <h2>📌 Сейчас читаю</h2>
      <span class="count-badge">2 книги</span>
    </div>
    <div class="book-grid">
      <!-- книга 1 -->
      <div class="book-card">
        <div class="book-cover">🌿</div>
        <div class="book-info">
          <div class="book-title">Сад расходящихся тропок</div>
          <div class="book-author">Х. Л. Борхес</div>
          <div class="progress-area">
            <div class="progress-bar-bg">
              <div class="progress-bar-fill" style="width: 64%;"></div>
            </div>
            <span class="progress-text">64%</span>
          </div>
        </div>
        <div style="color:#a28d78;">⌛</div>
      </div>
      <!-- книга 2 -->
      <div class="book-card">
        <div class="book-cover">🌊</div>
        <div class="book-info">
          <div class="book-title">Старик и море</div>
          <div class="book-author">Эрнест Хемингуэй</div>
          <div class="progress-area">
            <div class="progress-bar-bg">
              <div class="progress-bar-fill" style="width: 32%;"></div>
            </div>
            <span class="progress-text">32%</span>
          </div>
        </div>
        <div style="color:#a28d78;">⌛</div>
      </div>
    </div>
  </section>

  <!-- Прочитано недавно -->
  <section>
    <div class="section-header">
      <h2>✅ Прочитано</h2>
      <span class="count-badge">за месяц 4</span>
    </div>
    <div class="book-grid">
      <div class="book-card" style="opacity:0.95;">
        <div class="book-cover">🏹</div>
        <div class="book-info">
          <div class="book-title">Стрелок</div>
          <div class="book-author">Стивен Кинг</div>
          <div class="flex-row text-small" style="color:#6b5d4e;">⭐ 4.5 · закончена 2 дня назад</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Заметки и цитаты (основа читательского дневника) -->
  <section>
    <div class="section-header">
      <h2>✍️ Заметки & цитаты</h2>
      <span class="count-badge">3 записи</span>
    </div>
    <div class="notes-list">
      <div class="note-card">
        <div class="note-header">
          <span class="note-book">📘 Сад расходящихся тропок</span>
          <span class="note-date">сегодня</span>
        </div>
        <div class="note-quote">„В любом лабиринте можно заблудиться, но в лабиринте времени…“</div>
        <div class="note-text">Борхес напоминает о множественности путей. Великолепная метафора чтения.</div>
      </div>
      <div class="note-card">
        <div class="note-header">
          <span class="note-book">🌊 Старик и море</span>
          <span class="note-date">вчера</span>
        </div>
        <div class="note-quote">„Человек не для того создан, чтобы терпеть поражения.“</div>
        <div class="note-text">Потрясающая сцена с рыбой. Надо перечитать финал.</div>
      </div>
      <div class="note-card">
        <div class="note-header">
          <span class="note-book">🔫 Стрелок</span>
          <span class="note-date">3 дня назад</span>
        </div>
        <div class="note-text">Начало Тёмной Башни — суровый мир. Интересно, куда приведёт погоня.</div>
      </div>
    </div>
  </section>

  <!-- Статистика и цитата дня (вдохновение) -->
  <section>
    <div class="stats-container">
      <div class="stat-row">
        <span class="stat-label">📚 Книг в этом году</span>
        <span class="stat-number">12</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">⏳ Дней чтения подряд</span>
        <span class="stat-number">7 🔥</span>
      </div>
      <div class="stat-row">
        <span class="stat-label">📑 Всего заметок</span>
        <span class="stat-number">34</span>
      </div>
      <div class="quote-of-day">
        «Чтение — вот лучшее учение» <span style="font-style:normal;">— А.С. Пушкин</span>
      </div>
    </div>
  </section>

  <!-- Кнопка добавления (центральный элемент) -->
  <button class="fab-add" id="addEntryBtn" aria-label="Добавить запись">
    <span style="font-size:22px;">✏️</span> Новая запись
  </button>

  <!-- Нижняя навигация (эстетика iOS) -->
  <div class="tab-bar">
    <div class="tab-item active">
      <span class="tab-icon">📚</span>
      <span>Дневник</span>
    </div>
    <div class="tab-item">
      <span class="tab-icon">🔍</span>
      <span>Поиск</span>
    </div>
    <div class="tab-item">
      <span class="tab-icon">📊</span>
      <span>Статистика</span>
    </div>
    <div class="tab-item">
      <span class="tab-icon">⚙️</span>
      <span>Ещё</span>
    </div>
  </div>

  <!-- небольшая подсказка, что данные локальны -->
  <p style="text-align:center; margin-top: 16px; color:#988f84; font-size:12px;">📱 все записи на устройстве · эстетика читателя</p>
</div>

<script>
  (function(){
    // Делаем приложение живым — добавляем интерактив.
    // Визуал и функционал, подходящий для iPhone: плавные действия.

    const addBtn = document.getElementById('addEntryBtn');
    const bookGrids = document.querySelectorAll('.book-grid');
    const notesList = document.querySelector('.notes-list');
    const statNumberBooks = document.querySelector('.stat-number'); // первое число

    // имитация добавления новой заметки/книги — для демонстрации функциональности
    addBtn.addEventListener('click', function(e) {
      e.preventDefault();
      
      // Показываем окошко prompt (для простоты — демо добавления)
      let newBookTitle = prompt('📖 Название книги или заметки:', 'Новая книга');
      if (!newBookTitle) return;
      
      let noteText = prompt('💬 Ваша заметка / цитата:', 'Удивительная глава...');
      if (noteText === null) noteText = 'Нет заметки';
      
      // создаём карточку заметки в разделе заметок
      if (notesList) {
        const newNote = document.createElement('div');
        newNote.className = 'note-card';
        
        const today = new Date();
        const dateStr = today.toLocaleDateString('ru-RU', { day:'numeric', month:'short' }).replace('.', '');
        
        newNote.innerHTML = `
          <div class="note-header">
            <span class="note-book">📘 ${newBookTitle}</span>
            <span class="note-date">сегодня</span>
          </div>
          <div class="note-quote">„${noteText.slice(0, 40)}${noteText.length>40?'…':''}“</div>
          <div class="note-text">${noteText}</div>
        `;
        notesList.prepend(newNote); // сверху
        
        // обновим счётчик заметок
        const countBadges = document.querySelectorAll('.count-badge');
        if (countBadges.length >= 2) {
          const noteCountBadge = countBadges[2]; // третий - заметки
          const current = parseInt(noteCountBadge.innerText) || 3;
          noteCountBadge.innerText = (current + 1) + ' записи';
        }
        
        // обновим статистику (всего заметок)
        const statLabels = document.querySelectorAll('.stat-number');
        if (statLabels.length >= 3) {
          const totalNotesEl = statLabels[2];
          const currentNotes = parseInt(totalNotesEl.innerText) || 34;
          totalNotesEl.innerText = currentNotes + 1;
        }
        
        // добавим также небольшую анимацию
        newNote.style.transition = 'all 0.2s';
        newNote.style.opacity = '0';
        newNote.style.transform = 'translateY(8px)';
        setTimeout(() => {
          newNote.style.opacity = '1';
          newNote.style.transform = 'translateY(0)';
        }, 10);
      }

      // дополнительно можем показать новую книгу в "сейчас читаю" (для демо)
      if (confirm('Добавить эту книгу в раздел «Сейчас читаю»?')) {
        const currentlySection = document.querySelector('.section-header')?.parentElement;
        const firstBookGrid = document.querySelector('.book-grid');
        if (firstBookGrid) {
          const newBookCard = document.createElement('div');
          newBookCard.className = 'book-card';
          newBookCard.innerHTML = `
            <div class="book-cover">📘</div>
            <div class="book-info">
              <div class="book-title">${newBookTitle}</div>
              <div class="book-author">новый автор</div>
              <div class="progress-area">
                <div class="progress-bar-bg">
                  <div class="progress-bar-fill" style="width: 5%;"></div>
                </div>
                <span class="progress-text">5%</span>
              </div>
            </div>
            <div style="color:#a28d78;">⌛</div>
          `;
          firstBookGrid.appendChild(newBookCard);
          
          // обновим счётчик "сейчас читаю"
          const firstCount = document.querySelector('.count-badge');
          if (firstCount) {
            const currentCount = parseInt(firstCount.innerText) || 2;
            firstCount.innerText = (currentCount + 1) + ' книги';
          }
          
          // обновить общее кол-во книг в году (первая статусная цифра)
          const yearBooks = document.querySelectorAll('.stat-number')[0];
          if (yearBooks) {
            yearBooks.innerText = (parseInt(yearBooks.innerText) || 12) + 1;
          }
        }
      }
      
      // также демонстрируем плавное обновление streak (визуально)
    });

    // Добавим интерактив таб-бару: переключение активного состояния
    const tabs = document.querySelectorAll('.tab-item');
    tabs.forEach(tab => {
      tab.addEventListener('click', function(e) {
        tabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        // Можно менять контент, но для демо просто имитация
        const tabName = this.innerText.trim();
        if (tabName.includes('Статистика')) {
          alert('📊 Статистика: 12 книг в году, 7 дней чтения подряд, 35 заметок. (демо)');
        } else if (tabName.includes('Поиск')) {
          alert('🔍 Поиск по книгам и заметкам (в реальном приложении — умный поиск)');
        } else if (tabName.includes('Ещё')) {
          alert('⚙️ Настройки: тема, экспорт, резервное копирование.');
        }
      });
    });

    // Эффект нажатия на карточку книги — показать детали
    document.querySelectorAll('.book-card').forEach(card => {
      card.addEventListener('click', function() {
        const title = this.querySelector('.book-title')?.innerText || 'Книга';
        alert(`📚 ${title}\nЗдесь будет страница книги с полным прогрессом, заметками и цитатами.`);
      });
    });

    // Имитация обновления цитаты дня (можно добавить функционал)
    console.log('📖 Литературный дневник — всё для уютного чтения. Дизайн вдохновлён Almost Read, Book Diary и Apple Journal.');
  })();
</script>
</body>
</html>
